# Copy to .env in your config dir (default: ~/.google-ads-mcp/.env). Never commit this.
# The developer token comes from the Google Ads API Center in your manager (MCC) account.
GOOGLE_ADS_DEVELOPER_TOKEN=your_22_char_developer_token

# Your Google Cloud project id (the one where you enabled the Google Ads API + OAuth).
GOOGLE_PROJECT_ID=your-gcp-project-id

# Manager (MCC) account id, digits only, no dashes. Optional but usual for agencies.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# Default account a tool call uses when it doesn't specify one. Digits only. Optional.
GOOGLE_ADS_CUSTOMER_ID=1234567890
