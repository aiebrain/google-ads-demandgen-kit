# 이 파일을 config 디렉터리(기본 ~/.google-ads-mcp)에 .env 로 복사한 뒤 값을 채우세요.
# bootstrap.py 가 없으면 자동으로 복사해 줍니다. 절대 커밋/공유 금지.

# 관리자(MCC) 계정의 API 센터에서 받은 22자 개발자 토큰.
# https://ads.google.com/aw/apicenter  (처음엔 Test 등급 → Basic 승인 신청 필요)
GOOGLE_ADS_DEVELOPER_TOKEN=your_22_char_developer_token

# Google Ads API 를 활성화하고 OAuth 클라이언트를 만든 GCP 프로젝트 ID.
GOOGLE_PROJECT_ID=your-gcp-project-id

# 관리자(MCC) 계정 ID. 하이픈 없이 숫자 10자리.
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# 실제 광고가 도는 고객 계정 ID. 하이픈 없이 숫자. (검증·기본 대상 계정)
# 주의: 관리자(MCC) ID 가 아니라 광고가 running 중인 계정 ID 를 넣으세요.
GOOGLE_ADS_CUSTOMER_ID=1234567890
